# ============================================================
#  Suivi Matériel VPMI — Configuration
#  Copiez ce fichier en ".env" et remplissez les 4 valeurs.
#  (Voir le README, section "Configuration Azure AD")
# ============================================================

# --- Azure AD (App Registration) ---
# ID du locataire (Tenant ID) - onglet "Vue d'ensemble" de l'app
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# ID de l'application (Client ID)
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Secret client (Certificats & secrets > Nouveau secret client > "Valeur")
AZURE_CLIENT_SECRET=votre-secret-client

# --- SharePoint ---
# Nom d'hôte SharePoint, ex: vpmi.sharepoint.com
SHAREPOINT_HOSTNAME=vpmi.sharepoint.com
# Chemin du site, ex: /sites/Informatique  (laisser vide pour le site racine)
SHAREPOINT_SITE_PATH=/sites/Informatique
# Nom de la Liste SharePoint utilisée comme base de données
SHAREPOINT_LIST_NAME=Suivi Materiel

# --- Sécurité de l'application (optionnel) ---
# Mot de passe simple pour protéger l'accès. Laisser vide = pas de mot de passe.
APP_PASSWORD=
